# Perito — plantilla de configuración.  Copia este archivo a `.env` y rellena los SECRETOS:
#     cp env.example .env
# El `.env` está gitignorado (nunca se commitea). Las variables del shell (export ...) tienen
# prioridad sobre este archivo. Todo lo de aquí también acepta default en el código.

# ─────────────────────────────────────────────────────────────────────────────
# PÚBLICO — valores por defecto seguros (ya seteados; cámbialos solo si sabes por qué)
# ─────────────────────────────────────────────────────────────────────────────

# Persistencia: "memory" (efímero, default) | "postgres" (Neon; requiere DATABASE_URL con sslmode=require)
PERSISTENCE=memory

FAKER_LOCALE=es_CO

# Modelos (capas de costo de Perito): Haiku extrae, Sonnet verifica.
EXTRACTOR_MODEL=claude-haiku-4-5
VERIFIER_MODEL=claude-sonnet-5

# Cotas de terminación (P4) y umbral de confianza — defaults del código.
CONFIDENCE_THRESHOLD=0.70
MAX_ROUNDS=1
MAX_TOKENS_BUDGET=10000

# Región de Langfuse (pública). EU: https://cloud.langfuse.com  ·  US: https://us.cloud.langfuse.com
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ─────────────────────────────────────────────────────────────────────────────
# PRIVADO — LOS RELLENAS TÚ (secretos; déjalos vacíos para el tier sin costo)
# ─────────────────────────────────────────────────────────────────────────────

# Agentes Claude reales. Vacío → `make demo` corre en tier determinístico (presets, costo cero).
ANTHROPIC_API_KEY=

# Trazas a Langfuse. Vacíos → sink desactivado (solo floor JSON local).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Persistencia en Neon. Necesario solo si PERSISTENCE=postgres (arriba). Debe incluir sslmode=require (TLS, RNF-15).
#   Ej: postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/perito?sslmode=require
DATABASE_URL=
